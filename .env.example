# Runtime versions / port
ODOO_MAJOR=19
POSTGRES_VERSION=16
ODOO_HTTP_PORT=8069

# -------------------------------------------------------------------
# ISDS (Datová schránka) optional settings
# -------------------------------------------------------------------
# These values are injected into the odoo_web container environment.
# You can sync them to company settings with:
#   ./scripts/odoo_apply_isds_env.sh odoo19_cz_test
#
# Minimal local mode:
#   L10N_CZ_ISDS_ENABLED=false
#
# SOAP credential-check mode (test env):
#   L10N_CZ_ISDS_ENABLED=true
#   L10N_CZ_ISDS_MODE=soap_owner_info
#   L10N_CZ_ISDS_API_URL=https://ws1.czebox.cz/DS/DsManage
#   L10N_CZ_ISDS_TARGET_BOX_ID=avbq58e
#
# SOAP direct submit mode (CreateMessage, test env):
#   L10N_CZ_ISDS_ENABLED=true
#   L10N_CZ_ISDS_MODE=soap_create_message
#   L10N_CZ_ISDS_API_URL=https://ws1.czebox.cz/DS/dz
#   L10N_CZ_ISDS_TARGET_BOX_ID=avbq58e
#
# HTTP bridge mode:
#   L10N_CZ_ISDS_ENABLED=true
#   L10N_CZ_ISDS_MODE=http_json
#   L10N_CZ_ISDS_API_URL=https://your-isds-bridge.example/submit

L10N_CZ_ISDS_ENABLED=false
L10N_CZ_ISDS_MODE=http_json
L10N_CZ_ISDS_API_URL=
L10N_CZ_ISDS_USERNAME=
L10N_CZ_ISDS_PASSWORD=
# Optional metadata only (not serialized into SOAP CreateMessage envelope).
L10N_CZ_ISDS_SENDER_BOX_ID=
L10N_CZ_ISDS_TARGET_BOX_ID=pndaab6
L10N_CZ_ISDS_TIMEOUT_SECONDS=20
