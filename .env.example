ODOO_MAJOR=19
POSTGRES_VERSION=16
ODOO_HTTP_PORT=8069

# Optional ISDS bridge config for automated CZ VAT filing submission tests.
# Values from this file are passed to the `odoo_web` container and can be synced
# into company settings with `./scripts/odoo_apply_isds_env.sh`.
L10N_CZ_ISDS_ENABLED=
L10N_CZ_ISDS_MODE=http_json
L10N_CZ_ISDS_API_URL=
L10N_CZ_ISDS_USERNAME=
L10N_CZ_ISDS_PASSWORD=
L10N_CZ_ISDS_SENDER_BOX_ID=
L10N_CZ_ISDS_TARGET_BOX_ID=pndaab6
L10N_CZ_ISDS_TIMEOUT_SECONDS=20
