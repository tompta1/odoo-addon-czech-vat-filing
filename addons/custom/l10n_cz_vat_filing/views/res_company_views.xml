<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_company_form_l10n_cz_vat_filing" model="ir.ui.view">
    <field name="name">res.company.form.l10n.cz.vat.filing</field>
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form"/>
    <field name="arch" type="xml">
      <xpath expr="//notebook" position="inside">
        <page string="Czech VAT Filing">
          <group>
            <group>
              <button
                name="action_open_l10n_cz_vat_filing_export_wizard"
                type="object"
                string="Open Export Wizard"
                class="oe_highlight"
              />
              <button
                name="action_open_l10n_cz_vat_filing_history"
                type="object"
                string="Open Export History"
              />
              <field name="l10n_cz_vat_filing_history_count" readonly="1"/>
            </group>
            <group>
              <field name="l10n_cz_dph_use_manual_advance_coefficient"/>
              <field
                name="l10n_cz_dph_advance_coefficient"
                invisible="not l10n_cz_dph_use_manual_advance_coefficient"
              />
            </group>
            <group string="VAT Registry Shield">
              <field name="l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_api_url" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_vat_param" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_timeout_seconds" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_cache_hours" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_block_on_post" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_block_on_payment" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_block_unreliable" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_block_unpublished_bank" invisible="not l10n_cz_vat_registry_enabled"/>
              <field name="l10n_cz_vat_registry_block_on_lookup_error" invisible="not l10n_cz_vat_registry_enabled"/>
            </group>
            <group string="VAT FX (CNB)">
              <field name="l10n_cz_vat_fx_enforce_cnb"/>
              <field name="l10n_cz_vat_fx_api_url" invisible="not l10n_cz_vat_fx_enforce_cnb"/>
              <field name="l10n_cz_vat_fx_currency_param" invisible="not l10n_cz_vat_fx_enforce_cnb"/>
              <field name="l10n_cz_vat_fx_date_param" invisible="not l10n_cz_vat_fx_enforce_cnb"/>
              <field name="l10n_cz_vat_fx_timeout_seconds" invisible="not l10n_cz_vat_fx_enforce_cnb"/>
              <field name="l10n_cz_vat_fx_cache_days" invisible="not l10n_cz_vat_fx_enforce_cnb"/>
              <field name="l10n_cz_vat_fx_block_on_lookup_error" invisible="not l10n_cz_vat_fx_enforce_cnb"/>
            </group>
            <group string="Datova Schranka (ISDS)">
              <field name="l10n_cz_isds_enabled"/>
              <field name="l10n_cz_isds_mode" invisible="not l10n_cz_isds_enabled"/>
              <div class="alert alert-danger" role="alert"
                   invisible="not l10n_cz_isds_enabled or l10n_cz_isds_mode == 'mock'">
                <strong>⚠ Security Warning — Pověřená osoba credentials only</strong><br/>
                The ISDS username and password entered here must belong to a
                <em>Pověřená osoba</em> (authorised delegate) whose Data Box role is
                restricted to <strong>sending messages only</strong> — with
                <strong>no read-inbox privileges</strong>.<br/>
                Entering credentials of a user with inbox-read access would expose your
                entire Data Box inbox to this Odoo instance.  This module never calls
                <code>GetListOfReceivedMessages</code>, but least-privilege credentials
                eliminate any risk from future misconfiguration.
              </div>
              <field name="l10n_cz_isds_api_url" invisible="not l10n_cz_isds_enabled or l10n_cz_isds_mode == 'mock'"/>
              <field name="l10n_cz_isds_username" invisible="not l10n_cz_isds_enabled or l10n_cz_isds_mode == 'mock'"/>
              <field name="l10n_cz_isds_password" password="True" invisible="not l10n_cz_isds_enabled or l10n_cz_isds_mode == 'mock'"/>
              <field name="l10n_cz_isds_sender_box_id" invisible="not l10n_cz_isds_enabled"/>
              <field name="l10n_cz_isds_target_box_id" invisible="not l10n_cz_isds_enabled"/>
              <field name="l10n_cz_isds_timeout_seconds" invisible="not l10n_cz_isds_enabled"/>
              <field name="l10n_cz_isds_epo_poll_enabled" invisible="not l10n_cz_isds_enabled"/>
              <field name="l10n_cz_isds_adis_epo_url"
                     invisible="not l10n_cz_isds_enabled or not l10n_cz_isds_epo_poll_enabled"/>
            </group>
            <group string="XSD Schema Refresh">
              <field name="l10n_cz_xsd_dphdp3_url" placeholder="https://adisepo.mfcr.cz/…/dphdp3.xsd"/>
              <field name="l10n_cz_xsd_dphkh1_url" placeholder="https://adisepo.mfcr.cz/…/dphkh1.xsd"/>
              <field name="l10n_cz_xsd_dphshv_url" placeholder="https://adisepo.mfcr.cz/…/dphshv.xsd"/>
              <button
                name="action_l10n_cz_refresh_xsd_schemas"
                type="object"
                string="Refresh XSD Schemas"
                groups="base.group_system"
                confirm="This will overwrite the bundled XSD files on disk. Continue?"
              />
              <field
                name="l10n_cz_xsd_refresh_log"
                widget="text"
                readonly="1"
                invisible="not l10n_cz_xsd_refresh_log"
              />
            </group>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
